# TWRP recovery.fstab for Xiaomi lake - F2FS FIXED
# <src>                                  <mnt_point>            <type>   <mnt_flags>                         <fs_mgr_flags>

# Logical partitions (from super.img)
system                                  /system                ext4     rw                                  wait,slotselect,logical,first_stage_mount
system_ext                              /system_ext            ext4     rw                                  wait,slotselect,logical,first_stage_mount
vendor                                  /vendor                ext4     ro                                  wait,slotselect,logical,first_stage_mount
product                                 /product               ext4     rw                                  wait,slotselect,logical,first_stage_mount
mi_ext                                  /mi_ext                ext4     rw                                  wait,slotselect,logical,first_stage_mount,nofail
vendor_dlkm                             /vendor_dlkm           ext4     rw                                  wait,slotselect,logical,first_stage_mount
odm_dlkm                                /odm_dlkm              ext4     rw                                  wait,slotselect,logical,first_stage_mount
system_dlkm                             /system_dlkm           ext4     rw                                  wait,slotselect,logical,first_stage_mount

# Physical partitions
/dev/block/by-name/metadata             /metadata              ext4     noatime,nosuid,nodev,discard       wait,formattable
/dev/block/by-name/userdata             /data                  f2fs     rw,discard,inlinecrypt             wait,formattable,length=-16384,reservedsize=16384
/dev/block/by-name/rescue               /cache                 ext4     noatime,nosuid,nodev,noauto_da_alloc,discard   wait,formattable

# Protect & NV partitions (critical for IMEI/calibration backup)
/dev/block/by-name/protect1             /protect_f             ext4     noatime,nosuid,nodev,noauto_da_alloc,commit=1,nodelalloc   wait,formattable
/dev/block/by-name/protect2             /protect_s             ext4     noatime,nosuid,nodev,noauto_da_alloc,commit=1,nodelalloc   wait,formattable
/dev/block/by-name/nvdata               /nvdata                ext4     noatime,nosuid,nodev,noauto_da_alloc,commit=1,nodelalloc   wait,formattable
/dev/block/by-name/nvcfg                /nvcfg                 ext4     noatime,nosuid,nodev,noauto_da_alloc,commit=1,nodelalloc   wait,formattable
/dev/block/by-name/persist              /persist               ext4     noatime,nosuid,nodev,noauto_da_alloc,commit=1,nodelalloc   wait,formattable

# Firmware & boot partitions
/dev/block/by-name/boot                 /boot                  emmc     defaults                            defaults
/dev/block/by-name/dtbo                 /dtbo                  emmc     defaults                            defaults
/dev/block/by-name/vendor_boot          /vendor_boot           emmc     defaults                            defaults
/dev/block/by-name/init_boot            /init_boot             emmc     defaults                            defaults
/dev/block/by-name/md1img               /md1img                emmc     defaults                            defaults
/dev/block/by-name/modem                /modem                 emmc     defaults                            defaults
/dev/block/by-name/logo                 /logo                  emmc     defaults                            defaults
/dev/block/by-name/misc                 /misc                  emmc     defaults                            defaults
/dev/block/by-name/para                 /para                  emmc     defaults                            defaults
/dev/block/by-name/expdb                /expdb                 emmc     defaults                            defaults
/dev/block/by-name/frp                  /persistent            emmc     defaults                            defaults
/dev/block/by-name/nvram                /nvram                 emmc     defaults                            defaults
/dev/block/by-name/proinfo              /proinfo               emmc     defaults                            defaults
/dev/block/by-name/seccfg               /seccfg                emmc     defaults                            defaults
/dev/block/by-name/tee1                 /tee1                  emmc     defaults                            defaults
/dev/block/by-name/tee2                 /tee2                  emmc     defaults                            defaults
/dev/block/by-name/scp1                 /scp1                  emmc     defaults                            defaults
/dev/block/by-name/scp2                 /scp2                  emmc     defaults                            defaults
/dev/block/by-name/gz1                  /gz1                   emmc     defaults                            defaults
/dev/block/by-name/gz2                  /gz2                   emmc     defaults                            defaults
/dev/block/by-name/spmfw                /spmfw                 emmc     defaults                            defaults
/dev/block/by-name/vbmeta               /vbmeta                emmc     defaults                            defaults
/dev/block/by-name/vbmeta_vendor        /vbmeta_vendor         emmc     defaults                            defaults
/dev/block/by-name/vbmeta_system        /vbmeta_system         emmc     defaults                            defaults

# External storage
usb-otg                                 /usb-otg               vfat     defaults                            voldmanaged=usb-otg:auto
/devices/platform/11240000.mmc*         /external_sd           auto     defaults                            voldmanaged=sdcard1:auto,encryptable=userdata